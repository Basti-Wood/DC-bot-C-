# Copy this file to ".env" and fill in your values.
# NEVER commit the real .env file!

# ----- Database -----
DB_NAME=dcbot
DB_USER=dcbot
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_too

# ----- Bot 1 (main) -----
DISCORD_TOKEN_MAIN=your_bot_token_here
# Optional: register commands only in this guild (instant updates).
# Leave empty to register in every guild the bot is in.
GUILD_ID_MAIN=

# ----- Bot 2 (optional, start with: docker compose --profile second up -d) -----
DISCORD_TOKEN_SECOND=
GUILD_ID_SECOND=

# ----- AI (optional) -----
# OpenAI API key for the AI chat feature (/changeai backend:OpenAI)
GPT_TOKEN=
# Basti API key for the Basti AI backend AND the /rp Basti GIF source
BASTIAPI=

# ----- Misc -----
LOG_DEBUG=false

# ----- Local development only (running without Docker) -----
# When you run `dotnet run` locally, the bot reads DISCORD_TOKEN / BOT_ID
# directly instead of the compose mappings above:
# DISCORD_TOKEN=your_bot_token_here
# BOT_ID=main
# DB_HOST=localhost
# DB_PORT=3306
